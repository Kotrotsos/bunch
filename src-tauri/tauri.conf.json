{
  "productName": "Bunch",
  "version": "0.1.0",
  "identifier": "com.bunch.app",
  "bundle": {
    "icon": [
      "icons/icon.png"
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bunch - Claude Code Config Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          "$HOME/.claude/**",
          "$HOME/.claude"
        ]
      }
    }
  }
}
